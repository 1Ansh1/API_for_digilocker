# =============================================================================
# Application
# =============================================================================
APP_NAME=digilocker-verification-api
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=digilocker
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=digilocker_verification
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false

# =============================================================================
# DigiLocker Provider
# =============================================================================
DIGILOCKER_CLIENT_ID=your_client_id_here
DIGILOCKER_CLIENT_SECRET=your_client_secret_here
DIGILOCKER_AUTHORIZATION_URL=http://localhost:8001/authorize
DIGILOCKER_TOKEN_URL=http://localhost:8001/token
DIGILOCKER_JWKS_URL=http://localhost:8001/.well-known/jwks.json
DIGILOCKER_REDIRECT_URI=http://localhost:8000/api/v1/callback/digilocker
DIGILOCKER_SCOPES=openid

# =============================================================================
# Security
# =============================================================================
JWT_SECRET_KEY=changeme_in_production_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
HASH_SECRET_KEY=changeme_in_production_use_openssl_rand_hex_32

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_USER_MAX=5
RATE_LIMIT_USER_WINDOW_SECONDS=3600
RATE_LIMIT_IP_MAX=100
RATE_LIMIT_IP_WINDOW_SECONDS=60

# =============================================================================
# OAuth Session
# =============================================================================
OAUTH_SESSION_TTL_SECONDS=600
ACTIVE_LOCK_TTL_SECONDS=900
RESULT_TTL_SECONDS=300

# =============================================================================
# Observability
# =============================================================================
OTEL_SERVICE_NAME=digilocker-verification-api
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
OTEL_TRACE_SAMPLE_RATE=1.0
METRICS_ENABLED=true
